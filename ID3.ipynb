import numpy as np
import pandas as pd
df = pd.read_csv('/Test.csv')
Cl = "Buys"
Att = df.columns.tolist()
Att.remove("RID")
Att.remove(Cl)
def Entropy(df,CL):
    n = len(df)
    E = 0
    for i in df[CL].unique():
        k = len(df[df[CL] == i])
        E -=  (k/n) * (np.log(k/n)/np.log(2))
    return E
def SubEntropy(df, CL, Att):
    n = len(df)
    ans = 0
    for i in df[Att].unique():
        dff = df[df[Att] == i]
        k = len(dff)
        ans += (k/n) * Entropy(dff, CL)
    return ans        
def IG(df, CL, Att):
    return Entropy(df, CL) - SubEntropy(df, CL, Att)
def Selection(df, Cl, Att):
    ig = 0
    best = ""
    for i in Att:
        if (IG(df, Cl, i) > ig):
            best = i
            ig = IG(df, Cl, i)
        
    return best
def ID3(df, Cl, Att):
    # Case 1 : All examples belong to one class
    if len(df[Cl].unique()) == 1:
        return df[Cl].iloc[0]
    # Case 2 : No attributes left
    if len(Att) == 0:
        return df[Cl].mode()[0]
    # Select best attribute
    head = Selection(df, Cl, Att)
    tree = {head: {}}
    # Remaining attributes
    newAtt = Att.copy()
    newAtt.remove(head)
    # Build subtree for every attribute value
    for value in df[head].unique():
        dff = df[df[head] == value]
        tree[head][value] = ID3(dff, Cl, newAtt)
    return tree
def printTree(tree, level=0, parent="", branch=""):
    if not isinstance(tree, dict):
        if parent == "":
            print(tree, "-- level", level)
        else:
            print(tree, "(", parent, "=", branch, ")", "-- level", level)
        return
    for node in tree:
        if level == 0:
            print(node, "-- level", level)
        else:
            print(node, "(", branch, ")", "-- level", level)
        for value in tree[node]:
            printTree(tree[node][value], level + 1, node, value)
tree = ID3(df, "Buys", Att)
printTree(tree)